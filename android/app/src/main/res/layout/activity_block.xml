<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App blocked"
        android:textColor="#F9FAFB"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blocked_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Selected App"
        android:textColor="#93C5FD"
        android:textSize="18sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Complete a mindful unlock to continue"
        android:textColor="#D1D5DB"
        android:textSize="15sp" />

    <Button
        android:id="@+id/button_breathe_unlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text="Breathe to unlock" />

    <Button
        android:id="@+id/button_play_unlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Play game to unlock" />

    <Button
        android:id="@+id/button_exit_app"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Exit app" />

</LinearLayout>
